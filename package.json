{
  "name": "paid-knowledge-extraction-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "demo:mock": "DEMO_ARTIFACT_DIR=artifacts/demo-run node --import tsx scripts/demo-runner.ts",
    "demo:receipt:mock": "RECEIPT_MODE=mock DEMO_ARTIFACT_DIR=artifacts/receipt-demo node --import tsx scripts/demo-runner.ts",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:contracts": "forge test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^2.1.0",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "express": "^5.1.0",
    "viem": "^2.48.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.8.1",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
